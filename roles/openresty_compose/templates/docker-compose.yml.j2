---
services:
  openresty:
    image: {{ openresty_compose_image }}
    container_name: {{ openresty_compose_container_name }}
    restart: unless-stopped
    networks:
      - external_network
    volumes:
      - ./conf/default.conf:/etc/nginx/conf.d/default.conf:ro
      - ./auth/users.htpasswd:/etc/nginx/auth/users.htpasswd:ro
      - ./html:/usr/local/openresty/nginx/html:ro
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost/health"]
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 10s
    deploy:
      resources:
        limits:
          cpus: '1.0'
          memory: 500M
        reservations:
          cpus: '0.1'
          memory: 128M

networks:
  external_network:
    external: true
